{
  "name": "@rckflr/repomemory",
  "version": "2.17.0",
  "description": "Git-inspired agentic memory system — library + CLI",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "repomemory": "dist/cli.js",
    "repomemory-mcp": "dist/mcp.js",
    "repomemory-http": "dist/http.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./ai": {
      "import": "./dist/ai/index.js",
      "types": "./dist/ai/index.d.ts"
    },
    "./rag": {
      "import": "./dist/rag/index.js",
      "types": "./dist/rag/index.d.ts"
    },
    "./neural": {
      "import": "./dist/neural/index.js",
      "types": "./dist/neural/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@huggingface/transformers": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@huggingface/transformers": {
      "optional": true
    }
  },
  "keywords": [
    "ai",
    "memory",
    "agent",
    "mcp",
    "context",
    "knowledge-base",
    "versioned-storage",
    "neural",
    "embeddings",
    "semantic-search"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rckflr/repomemory-v2.git"
  },
  "license": "MIT"
}
